{{!-- ════════════════════════════════════════════════════════════════════════
  SESSION XP AWARD PANEL
  GM-only. End-of-session XP distribution across all PCs.
  RAW Ch3: Attendance (1), Thespianism (1), OOC (1), Problems (1), Plot (1).
════════════════════════════════════════════════════════════════════════ --}}

<div class="xa-wrapper">

  {{!-- ══ Header ══ --}}
  <div class="xa-header">
    <div class="xa-header-left">
      <span class="xa-title-text">Session XP Awards</span>
      {{#if activeChars}}
      <span class="xa-count-badge">{{activeChars}}/{{totalChars}} characters</span>
      {{/if}}
    </div>
    <div class="xa-header-actions">
      <button type="button" class="xa-header-btn xa-header-btn-muted" data-action="resetAll" title="Reset all bonuses and exclusions">
        <i class="fas fa-undo"></i> Reset
      </button>
      <button type="button" class="xa-header-btn xa-header-btn-primary" data-action="applyAwards" title="Apply all awards to characters">
        <i class="fas fa-check"></i> Award {{grandTotal}} XP
      </button>
    </div>
  </div>

  {{!-- ══ Base Award Row ══ --}}
  <div class="xa-base-row">
    <div class="xa-base-field">
      <label class="xa-base-label" title="RAW: Attendance (1) + Dramatic Plot (0–1). Applied equally to all included characters.">
        <i class="fas fa-users"></i> Base Award (all PCs)
      </label>
      <input type="number" class="xa-base-input" value="{{baseAward}}" min="0" max="10" />
    </div>
    <div class="xa-base-hint">
      Attendance + Plot. Individual bonuses (Thespianism, OOC, Problems) go in the per-character Bonus column below.
    </div>
  </div>

  {{!-- ══ Empty State ══ --}}
  {{#if isEmpty}}
  <div class="xa-empty">
    <i class="fas fa-award xa-empty-icon"></i>
    <p class="xa-empty-title">No characters found</p>
    <p class="xa-empty-sub">Create character actors with player ownership to use the XP Award Panel.</p>
  </div>
  {{/if}}

  {{!-- ══ Character List ══ --}}
  {{#unless isEmpty}}
  <div class="xa-list-header">
    <span class="xa-col-name">Character</span>
    <span class="xa-col-xp">Current</span>
    <span class="xa-col-bonus">Bonus</span>
    <span class="xa-col-total">Award</span>
    <span class="xa-col-after">After</span>
  </div>

  <div class="xa-list wt-scroll-y">
    {{#each characters}}
    <div class="xa-entry {{#if this.excluded}}xa-entry-excluded{{/if}}" data-actor-id="{{this.id}}">

      {{!-- Toggle inclusion --}}
      <button type="button" class="xa-include-btn {{#unless this.excluded}}xa-included{{/unless}}"
              data-action="toggleExclude"
              title="{{#if this.excluded}}Click to include in awards{{else}}Click to exclude from awards{{/if}}">
        {{#if this.excluded}}
          <i class="fas fa-times-circle"></i>
        {{else}}
          <i class="fas fa-check-circle"></i>
        {{/if}}
      </button>

      {{!-- Portrait + Name --}}
      <div class="xa-char-identity">
        <img src="{{this.img}}" alt="{{this.name}}" class="xa-portrait" />
        <div class="xa-char-info">
          <span class="xa-char-name">{{this.name}}</span>
          <span class="xa-char-earned">{{this.earned}} earned</span>
        </div>
      </div>

      {{!-- Current unspent --}}
      <span class="xa-xp-current" title="Unspent: {{this.unspent}} · Spent: {{this.spent}}">
        {{this.unspent}}
      </span>

      {{!-- Individual bonus --}}
      <input type="number" class="xa-bonus-input" value="{{this.bonus}}" min="0" max="5"
             title="Individual bonus for this character (Thespianism, OOC, Problems)"
             {{#if this.excluded}}disabled{{/if}} />

      {{!-- Total award --}}
      <span class="xa-xp-total {{#if this.total}}xa-has-award{{/if}}">
        {{#if this.excluded}}—{{else}}+{{this.total}}{{/if}}
      </span>

      {{!-- After award --}}
      <span class="xa-xp-after" title="XP after award is applied">
        {{this.afterAward}}
      </span>

    </div>
    {{/each}}
  </div>
  {{/unless}}

</div>
