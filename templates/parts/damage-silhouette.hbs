{{!--
  Damage Silhouette · Sprint 3.2 revised (3.2.3 hotfix)

  Per-zone clip-paths: each body part has its own clip polygon. Damage
  rects, crack patterns, and lightning overlays all use the per-zone
  clip so colour fills follow the body contour rather than appearing
  as block rectangles.

  Click overlays: small rectangles positioned at natural label anchor
  points (per user's annotated reference) — head, shoulders for arms,
  central trunk for torso, upper thighs for legs.

  Layering:
    1. White base figure
    2. Damage fills, crack overlays, lightning — each per-zone clipped
    3. Solid-black destroyed overlay (per-zone clipped)
    4. Ink outline (LAST so it stays crisp)
    5. Invisible click overlays + tooltips
--}}
<div class="wt-silhouette-container">
  <svg class="damage-silhouette" viewBox="60 0 87 207" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
    <defs>
      {{!-- The reference figure path. Reused by the visible <use>s below. --}}
      <path id="ref-silhouette-{{appId}}" d="M104.3,118.0c-0.3,3.6,2.1,22.5,3.4,30.0c0.6,3.5,2.2,9.3,1.6,12.3 c-0.8,4.2-1.1,9.7-0.6,12.9c0.3,1.9,1.2,10.9-0.1,14.2c-0.7,1.7-1.9,10.5-1.9,10.5 c-3.3,8.3-1.4,7.9-1.4,7.9c1.0,1.2,2.8,0.1,2.8,0.1c1.3,0.8,2.2-0.2,2.2-0.2 c1.1,0.9,2.5-0.1,2.5-0.1c1.4,0.7,2.8-0.6,2.8-0.6c0.8,0.4,1.0-0.1,1.0-0.1 c2.5-0.2-1.4-8.1-1.4-8.1c-0.9-7.1,0.9-11.0,0.9-11.0c6.0-17.8,6.3-22.5,3.9-29.2 c-0.7-1.9-0.8-2.7-0.5-3.5c0.7-1.9,0.2-9.7,1.1-12.8c1.7-6.0,3.4-21.1,4.2-28.2 c1.2-9.5-4.1-22.3-4.1-22.3c-1.2-5.2,0.5-23.7,0.5-23.7c2.4,3.7,2.3,10.2,2.3,10.2 c-0.4,6.9,5.5,17.3,5.5,17.3c2.8,4.3,3.9,8.4,3.9,8.7c0,1.2-0.3,4.3-0.3,4.3l0.1,2.6 c0.0,0.7,0.4,3.0,0.4,4.1c-0.4,6.9,0.6,5.6,0.6,5.6c0.9,0,1.9-5.5,1.9-5.5 c0,1.4-0.3,5.7,0.4,7.3c0.9,1.9,1.6-0.3,1.6-0.8c0.2-8.7,0.8-6.4,0.8-6.4 c0.5,7.1,1.1,8.7,2.3,8.1c0.9-0.4,0.1-8.5,0.1-8.5c1.5,4.8,2.6,5.6,2.6,5.6 c2.4,1.7,0.9-3.0,0.6-3.9c-1.8-4.9-1.8-6.6-1.8-6.6c2.2,4.4,3.9,4.3,3.9,4.3 c2.2-0.7-1.9-7.0-4.3-10.0c-1.2-1.5-2.8-3.6-3.2-4.8c-0.7-2.1-1.3-8.7-1.3-8.7 c-0.2-7.8-2.2-11.2-2.2-11.2c-3.3-5.3-3.9-15.1-3.9-15.1l-0.1-16.6 c-1.2-11.3-9.5-11.4-9.5-11.4c-8.5-1.3-9.6-4.0-9.6-4.0c-1.8-2.6-0.8-7.5-0.8-7.5 c1.5-1.2,2.1-4.4,2.1-4.4c2.5-1.9,2.3-4.7,1.2-4.6c-0.9,0.0-0.7-0.7-0.7-0.7 C115.1,0.6,104.0,0,104.0,0h-1.7c0,0-11.1,0.6-9.5,13.1c0,0,0.2,0.8-0.7,0.7 c-1.1-0.0-1.2,2.7,1.2,4.6c0,0,0.6,3.2,2.1,4.4c0,0,1.0,4.9-0.8,7.5c0,0-1.2,2.7-9.6,4.0 c0,0-8.4,0.1-9.5,11.4l-0.2,16.6c0,0-0.6,9.9-3.9,15.1c0,0-1.9,3.4-2.1,11.2 c0,0-0.6,6.6-1.3,8.7c-0.5,1.2-2.0,3.3-3.2,4.8c-2.4,3.0-6.5,9.2-4.3,10.0 c0,0,1.7,0.2,3.9-4.3c0,0-0.0,1.7-1.8,6.6c-0.3,0.9-1.8,5.6,0.6,3.9c0,0,1.1-0.8,2.6-5.6 c0,0-0.8,8.1,0.1,8.5c1.1,0.6,1.8-1.0,2.3-8.1c0,0,0.5-2.3,0.8,6.4 c0.0,0.5,0.7,2.7,1.6,0.8c0.8-1.6,0.4-5.9,0.4-7.3c0,0,1.0,5.5,1.9,5.5 c0,0,1.1,1.3,0.6-5.6c-0.1-1.1,0.3-3.4,0.4-4.1l0.1-2.6c0,0-0.3-3.0-0.3-4.3 c0-0.3,1.1-4.4,3.9-8.7c0,0,5.9-10.5,5.5-17.3c0,0-0.1-6.5,2.3-10.2c0,0,1.7,18.5,0.5,23.7 c0,0-5.3,12.8-4.1,22.3c0.9,7.1,2.5,22.2,4.2,28.2c0.9,3.1,0.4,10.9,1.1,12.8 c0.3,0.8,0.2,1.6-0.5,3.5c-2.4,6.7-2.1,11.4,3.9,29.2c0,0,1.8,3.9,0.9,11.0 c0,0-3.8,7.9-1.4,8.1c0,0,0.2,0.5,1.0,0.1c0,0,1.3,1.4,2.8,0.6c0,0,1.3,1.1,2.5,0.1 c0,0,0.9,1.0,2.2,0.2c0,0,1.7,1.2,2.8-0.1c0,0,1.8,0.4-1.4-7.9c0,0-1.3-8.8-1.9-10.5 c-1.3-3.3-0.4-12.3-0.1-14.2c0.5-3.2,0.2-8.7-0.6-12.9c-0.6-3.0,1.0-8.8,1.6-12.3 c1.2-7.4,3.7-26.4,3.4-30.0l1.0,0.4C103.8,118.3,104.3,118.0,104.3,118.0z"/>

      {{!-- Per-zone clip-paths. Each polygon roughly traces one body
           part's contour. They tile to cover the whole figure with no
           overlap. Drawn slightly larger than the visible body outline
           so the figure's own clip-path (below) trims any overshoot. --}}

      {{!-- HEAD: oval around head + neck stub --}}
      <clipPath id="cp-head-{{appId}}">
        <ellipse cx="103" cy="22" rx="20" ry="22"/>
      </clipPath>

      {{!-- TORSO: hourglass from shoulders to crotch.
           v3.2.4: NARROWED at the top (x=84..122 at y=38, was 76..130) so
           the deltoid/shoulder area belongs to the ARMS, not the torso.
           This stops the torso fill from bleeding across the shoulders. --}}
      <clipPath id="cp-torso-{{appId}}">
        <path d="M 84,38 L 122,38 L 126,68 L 128,90 L 126,108 L 122,120 L 108,134 L 98,134 L 84,120 L 80,108 L 78,90 L 80,68 Z"/>
      </clipPath>

      {{!-- LEFT ARM (viewer's left side).
           v3.2.4: WIDENED at the top (x=58..84 at y=38) to take over the
           deltoid the torso used to claim. --}}
      <clipPath id="cp-armL-{{appId}}">
        <path d="M 58,38 L 84,38 L 80,72 L 78,100 L 72,124 L 64,130 L 58,128 L 56,118 L 60,100 L 60,72 Z"/>
      </clipPath>

      {{!-- RIGHT ARM (viewer's right side).
           v3.2.4: WIDENED at the top (x=122..148 at y=38). --}}
      <clipPath id="cp-armR-{{appId}}">
        <path d="M 122,38 L 148,38 L 146,72 L 146,100 L 150,118 L 148,128 L 142,130 L 134,124 L 128,100 L 126,72 Z"/>
      </clipPath>

      {{!-- LEFT LEG (viewer's left side) — thigh to foot.
           v3.2.4: TOP moved up from y=128 to y=118 so the leg fill reaches
           the hip with no white gap. Matches LIMB_GEOM legL.top in JS. --}}
      <clipPath id="cp-legL-{{appId}}">
        <path d="M 78,118 L 104,118 L 104,160 L 102,200 L 100,208 L 84,208 L 82,170 L 78,140 Z"/>
      </clipPath>

      {{!-- RIGHT LEG (viewer's right side).
           v3.2.4: TOP moved up from y=128 to y=118. --}}
      <clipPath id="cp-legR-{{appId}}">
        <path d="M 104,118 L 128,118 L 128,140 L 126,170 L 122,208 L 106,208 L 106,200 L 104,160 Z"/>
      </clipPath>

      {{!-- Whole-figure clip — used as a second-layer trim so per-zone
           overshoot can't escape the silhouette outline. Inlined directly
           because some renderers don't reliably resolve <use> in clipPath. --}}
      <clipPath id="figure-clip-{{appId}}">
        <path d="M104.3,118.0c-0.3,3.6,2.1,22.5,3.4,30.0c0.6,3.5,2.2,9.3,1.6,12.3 c-0.8,4.2-1.1,9.7-0.6,12.9c0.3,1.9,1.2,10.9-0.1,14.2c-0.7,1.7-1.9,10.5-1.9,10.5 c-3.3,8.3-1.4,7.9-1.4,7.9c1.0,1.2,2.8,0.1,2.8,0.1c1.3,0.8,2.2-0.2,2.2-0.2 c1.1,0.9,2.5-0.1,2.5-0.1c1.4,0.7,2.8-0.6,2.8-0.6c0.8,0.4,1.0-0.1,1.0-0.1 c2.5-0.2-1.4-8.1-1.4-8.1c-0.9-7.1,0.9-11.0,0.9-11.0c6.0-17.8,6.3-22.5,3.9-29.2 c-0.7-1.9-0.8-2.7-0.5-3.5c0.7-1.9,0.2-9.7,1.1-12.8c1.7-6.0,3.4-21.1,4.2-28.2 c1.2-9.5-4.1-22.3-4.1-22.3c-1.2-5.2,0.5-23.7,0.5-23.7c2.4,3.7,2.3,10.2,2.3,10.2 c-0.4,6.9,5.5,17.3,5.5,17.3c2.8,4.3,3.9,8.4,3.9,8.7c0,1.2-0.3,4.3-0.3,4.3l0.1,2.6 c0.0,0.7,0.4,3.0,0.4,4.1c-0.4,6.9,0.6,5.6,0.6,5.6c0.9,0,1.9-5.5,1.9-5.5 c0,1.4-0.3,5.7,0.4,7.3c0.9,1.9,1.6-0.3,1.6-0.8c0.2-8.7,0.8-6.4,0.8-6.4 c0.5,7.1,1.1,8.7,2.3,8.1c0.9-0.4,0.1-8.5,0.1-8.5c1.5,4.8,2.6,5.6,2.6,5.6 c2.4,1.7,0.9-3.0,0.6-3.9c-1.8-4.9-1.8-6.6-1.8-6.6c2.2,4.4,3.9,4.3,3.9,4.3 c2.2-0.7-1.9-7.0-4.3-10.0c-1.2-1.5-2.8-3.6-3.2-4.8c-0.7-2.1-1.3-8.7-1.3-8.7 c-0.2-7.8-2.2-11.2-2.2-11.2c-3.3-5.3-3.9-15.1-3.9-15.1l-0.1-16.6 c-1.2-11.3-9.5-11.4-9.5-11.4c-8.5-1.3-9.6-4.0-9.6-4.0c-1.8-2.6-0.8-7.5-0.8-7.5 c1.5-1.2,2.1-4.4,2.1-4.4c2.5-1.9,2.3-4.7,1.2-4.6c-0.9,0.0-0.7-0.7-0.7-0.7 C115.1,0.6,104.0,0,104.0,0h-1.7c0,0-11.1,0.6-9.5,13.1c0,0,0.2,0.8-0.7,0.7 c-1.1-0.0-1.2,2.7,1.2,4.6c0,0,0.6,3.2,2.1,4.4c0,0,1.0,4.9-0.8,7.5c0,0-1.2,2.7-9.6,4.0 c0,0-8.4,0.1-9.5,11.4l-0.2,16.6c0,0-0.6,9.9-3.9,15.1c0,0-1.9,3.4-2.1,11.2 c0,0-0.6,6.6-1.3,8.7c-0.5,1.2-2.0,3.3-3.2,4.8c-2.4,3.0-6.5,9.2-4.3,10.0 c0,0,1.7,0.2,3.9-4.3c0,0-0.0,1.7-1.8,6.6c-0.3,0.9-1.8,5.6,0.6,3.9c0,0,1.1-0.8,2.6-5.6 c0,0-0.8,8.1,0.1,8.5c1.1,0.6,1.8-1.0,2.3-8.1c0,0,0.5-2.3,0.8,6.4 c0.0,0.5,0.7,2.7,1.6,0.8c0.8-1.6,0.4-5.9,0.4-7.3c0,0,1.0,5.5,1.9,5.5 c0,0,1.1,1.3,0.6-5.6c-0.1-1.1,0.3-3.4,0.4-4.1l0.1-2.6c0,0-0.3-3.0-0.3-4.3 c0-0.3,1.1-4.4,3.9-8.7c0,0,5.9-10.5,5.5-17.3c0,0-0.1-6.5,2.3-10.2c0,0,1.7,18.5,0.5,23.7 c0,0-5.3,12.8-4.1,22.3c0.9,7.1,2.5,22.2,4.2,28.2c0.9,3.1,0.4,10.9,1.1,12.8 c0.3,0.8,0.2,1.6-0.5,3.5c-2.4,6.7-2.1,11.4,3.9,29.2c0,0,1.8,3.9,0.9,11.0 c0,0-3.8,7.9-1.4,8.1c0,0,0.2,0.5,1.0,0.1c0,0,1.3,1.4,2.8,0.6c0,0,1.3,1.1,2.5,0.1 c0,0,0.9,1.0,2.2,0.2c0,0,1.7,1.2,2.8-0.1c0,0,1.8,0.4-1.4-7.9c0,0-1.3-8.8-1.9-10.5 c-1.3-3.3-0.4-12.3-0.1-14.2c0.5-3.2,0.2-8.7-0.6-12.9c-0.6-3.0,1.0-8.8,1.6-12.3 c1.2-7.4,3.7-26.4,3.4-30.0l1.0,0.4C103.8,118.3,104.3,118.0,104.3,118.0z"/>
      </clipPath>

      {{!-- Killing-damage crack pattern. Tiles across the red band. --}}
      <pattern id="crack-pattern-{{appId}}" x="0" y="0" width="14" height="16" patternUnits="userSpaceOnUse">
        <path d="M 7,1 L 5,5 L 9,8 L 4,12 L 9,15" fill="none" stroke="#4A0E12" stroke-width="0.5" stroke-linejoin="round"/>
        <path d="M 5,5 L 1,3 M 9,8 L 13,6 M 4,12 L 0,13 M 9,15 L 14,14" fill="none" stroke="#4A0E12" stroke-width="0.4"/>
      </pattern>
    </defs>

    {{!-- LAYER 1: White base figure --}}
    <use href="#ref-silhouette-{{appId}}" fill="#FFFFFF" stroke="none"/>

    {{!-- LAYER 2: Damage fills per zone.
         Outer <g> = whole-figure clip (silhouette trim).
         Inner rects = per-zone clip (body-part trim).
         Two-layer clipping keeps colour strictly inside the body part
         AND strictly inside the silhouette outline. --}}
    {{#each health as |loc key|}}
      {{#if loc.dmgFill}}
        <g clip-path="url(#figure-clip-{{@root.appId}})">
          {{#if loc.killBandHeight}}
            <rect x="50" y="{{loc.killBandY}}" width="110" height="{{loc.killBandHeight}}"
                  fill="#E11D48" clip-path="url(#cp-{{key}}-{{@root.appId}})"/>
          {{/if}}
          {{#if loc.shockBandHeight}}
            <rect x="50" y="{{loc.shockBandY}}" width="110" height="{{loc.shockBandHeight}}"
                  fill="#005AE0" clip-path="url(#cp-{{key}}-{{@root.appId}})"/>
          {{/if}}
        </g>
      {{/if}}
    {{/each}}

    {{!-- LAYER 3: Destroyed zones (solid black, per-zone clipped) --}}
    {{#each health as |loc key|}}
      {{#if loc.isDestroyed}}
        <g clip-path="url(#figure-clip-{{@root.appId}})">
          <rect x="50" y="0" width="110" height="220"
                fill="#1A1A1A" clip-path="url(#cp-{{key}}-{{@root.appId}})"/>
        </g>
      {{/if}}
    {{/each}}

    {{!-- LAYER 4: Crack pattern overlays (per killing band, per-zone clipped) --}}
    {{#each health as |loc key|}}
      {{#if loc.killBandHeight}}
        <g class="dmg-cracks" clip-path="url(#figure-clip-{{@root.appId}})">
          <rect x="50" y="{{loc.killBandY}}" width="110" height="{{loc.killBandHeight}}"
                fill="url(#crack-pattern-{{@root.appId}})"
                clip-path="url(#cp-{{key}}-{{@root.appId}})"/>
        </g>
      {{/if}}
    {{/each}}

    {{!-- LAYER 5: Lightning overlays. DOUBLE-CLIPPED (v3.2.4):
         outer = whole figure (so a branch can't escape the silhouette),
         inner = per-zone (so a torso bolt can't extend into an arm). --}}
    {{#each health as |loc key|}}
      {{#if loc.lightning}}
        <g clip-path="url(#figure-clip-{{@root.appId}})">
          <g class="dmg-lightning" clip-path="url(#cp-{{key}}-{{@root.appId}})">
            <path class="bolt-trunk" d="{{loc.lightning.trunk}}"/>
            {{#if loc.lightning.hasBranches}}
              <path class="bolt-branches" d="{{loc.lightning.branches}}"/>
            {{/if}}
            <circle class="bolt-spark" cx="{{loc.lightning.originX}}" cy="{{loc.lightning.originY}}" r="1.4"/>
          </g>
        </g>
      {{/if}}
    {{/each}}

    {{!-- LAYER 6: Ink outline (LAST so it stays crisp over all the colour) --}}
    <use href="#ref-silhouette-{{appId}}" fill="none" stroke="#1A1A1A" stroke-width="0.7" stroke-linejoin="round"/>

    {{!-- LAYER 7: Invisible click overlays at the natural label anchor
         points from the user's annotated reference. Small tap-targets,
         not full-zone rectangles. Order: TORSO first, then ARMS and
         LEGS so limbs win clicks at any shared edge.
         Naming: armR/legR = viewer's RIGHT side; armL/legL = viewer's LEFT. --}}
    <g class="hit-zone {{health.torso.status}}" data-loc="torso">
      <title>{{health.torso.tooltip}}</title>
      <rect x="88" y="60" width="32" height="50" fill="transparent" pointer-events="all"/>
    </g>
    <g class="hit-zone {{health.head.status}}" data-loc="head">
      <title>{{health.head.tooltip}}</title>
      <rect x="90" y="4" width="26" height="32" fill="transparent" pointer-events="all"/>
    </g>
    <g class="hit-zone {{health.armL.status}}" data-loc="armL">
      <title>{{health.armL.tooltip}}</title>
      <rect x="62" y="42" width="18" height="30" fill="transparent" pointer-events="all"/>
    </g>
    <g class="hit-zone {{health.armR.status}}" data-loc="armR">
      <title>{{health.armR.tooltip}}</title>
      <rect x="128" y="42" width="18" height="30" fill="transparent" pointer-events="all"/>
    </g>
    <g class="hit-zone {{health.legL.status}}" data-loc="legL">
      <title>{{health.legL.tooltip}}</title>
      <rect x="86" y="138" width="18" height="40" fill="transparent" pointer-events="all"/>
    </g>
    <g class="hit-zone {{health.legR.status}}" data-loc="legR">
      <title>{{health.legR.tooltip}}</title>
      <rect x="104" y="138" width="18" height="40" fill="transparent" pointer-events="all"/>
    </g>
  </svg>
</div>
